        },
        "legend_template": {
            "default_value": "<expver> <parameter> <domain_name> <variable> <statistic>"
        },
        "has_xtitle": {
            "default_value": true
        },
        "_xtitle_template": {
            "default_value": "<type> <parameter> <unit>"
        },
        "has_ytitle": {
            "default_value": true
        },
        "_ytitle_template": {
            "default_value": "<levtype>"
        }
	}
}
