[fc]
root_tmpl=/home/dao_ops/<expver>/run/.../archive/forecast
tree_tmpl=Ydate(@Y)/Mdate(@m)/Ddate(@d)/Hdate(@H)
file_tmpl=<expver>.<collection>.date(@Y@m@d_@Hz)+valid(@Y@m@d_@H@Mz).hdf
archive_type=dmf

[an]
root_tmpl=/home/dao_ops/<expver>/run/.../archive/das
tree_tmpl=Ydate(@Y)/Mdate(@m)/Ddate(@d)/Hdate(@H)
file_tmpl=<expver>.<collection>.date(@Y@m@d_@H@Mz).hdf
dap=<dap_root>s/assim/<collection>
archive_type=dmf

[ob]
root_tmpl=/gpfsm/dnb42/projects/p17/production/GEOS5odas-4.0
tree_tmpl=<expver>/odas/ods
file_tmpl=odas-<collection>_date(@Y@m@d@H).ods
archive_type=filesystem

[im]
root_tmpl=/archive/dao_ops/GEOS-5_pre_ops/GEOSadas-<d1>_<d2>_<d3>/<expver>/obs
tree_tmpl=Ydate(@Y)/Mdate(@m)/Ddate(@d)/Hdate(@H)
file_tmpl=<expver>.imp3_txe_<collection>.obs.date-9(@Y@m@d_@Hz)+date+24(@Y@m@d_@Hz)-date(@Y@m@d_@Hz).ods
archive_type=dmf
