{
	"directive": "obsdata",
    "inherit_from": "identifier",
    "doc": true,
	"keywords" : {
        "statistic": {
            "alias": ["stat","stats","statistics"],
            "optional": true,
            "help": ["the list of statistics to compute or retrieve for the specified set of observations","current statistics: {statisticList(flat)}"]
        },
        "colormap_statistic": {
            "optional": true,
            "unique": true,
            "help": ["the statistic to use to color the colormap associated to the bars in the plot"]
        },
        "date": {
            "type":"int",
            "optional": true,
            "help": ["A list of dates. The convenience function in <semperpy.core.date.Dates> can ","generate lists of dates from an interval and an increment"]
        },
        "domain_name": {
            "alias": ["domain"],
            "optional": true,
            "validate": ["ValidateDomains","semperpy"],
            "help": ["Pre-defined geographical areas or domains: {domainList(semperpy)}"]
        },
        "usage": {
            "default_value": "used",
            "validate": ["ValidateChoice","used","all","passive","unused","2","3","36"]
        },
        "variable": {
            "validate": ["ValidateChoice","obs","omf","oma","xvec","esigo","esigb","xm"],
            "optional": true
        },
        "level": {
            "alias": "channel",
            "type":"float",
            "optional": true,
            "ignore_type_errors": true,
            "help": ["The pressure level for upper air observations, 0 for surface,","or the channel number for satellite data, hence the alias <channel>. If 'all' is specified, the official list of pressure levels or channels for the kx-kt observations being processed are used."]
        },
        "levtype": {
            "alias": "leveltype",
            "optional": true,
            "unique": true
        },
        "kx": {
            "alias": "obssource",
            "type": "int",
            "optional": true,
            "help": ["Identifier of the observation source system"]
        },
        "kt": {
            "alias": "obstype",
            "type": "int",
            "optional": true,
            "help": ["Identifier of the type of observations"]
        },
        "filename": {
            "optional": true,
            "lowercase": false,
            "help": ["File containing a list of kx, kt identifiers to process"]
        },
        "type": {
			"validate": ["ValidateChoice","ob","im"],
            "default_value": "ob",
            "unique": true
        },
        "database": {
            "default_value": "ob_ops",
            "unique": true
        },
        "datefile": {
            "unique": true,
            "optional": true
        },
        "storage": {
            "unique": true,
            "default_value": "dbreader"
        },
        "name": {
            "unique": true,
            "optional": true
        },
        "_columns": {
            "default_value": ["level","statistic","date","value","count"]
        }
    }
}
