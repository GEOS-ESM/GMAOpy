{
	"directive": "fieldplot",
    "inherit_from": "baseplot",
    "doc": true,
	"keywords" : {
        "ignore_missing_files": {
            "alias": "ignore_missing",
            "default_value": false,
            "unique": true,
            "help": ["When accessing files, if a file is missing, the application","can either fail and report the error, or ignore","the problem and carry on"]
        },
        "staging_rate": {
            "unique": true,
            "default_value": "hourly",
            "lowercase": false
        },
        "root_tmpl": {
            "optional": true,
            "unique": true,
            "lowercase": false
        },
        "tree_tmpl": {
            "optional": true,
            "unique": true,
            "lowercase": false
        },
        "file_tmpl": {
            "optional": true,
            "unique": true,
            "lowercase": false
        },
        "archive_type": {
            "optional": true,
            "unique": true
        }
	}
}
